# NetPaceX Configuration Example
# Copy this file to .env and adjust the values

# Access password for sensitive settings (Mask MAC, History Deletion)
# If empty, these features will be disabled.
APP_PASSWORD=your_secure_password_here

# System Timezone (e.g., Asia/Jakarta, America/New_York, UTC)
TZ=Asia/Jakarta

# Application Port
PORT=8080

# Speed Test Engine (ookla or mlab)
WAN_ENGINE=mlab
